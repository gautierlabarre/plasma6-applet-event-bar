msgid "Events"
msgstr "Termine"

msgid "upcoming"
msgstr "bevorstehend"

msgid "Today"
msgstr "Heute"

msgid "Tomorrow"
msgstr "Morgen"

msgctxt "time since event started, in minutes"
msgid "%1min ago"
msgstr "vor %1min"

msgctxt "time since event started, in hours"
msgid "%1h ago"
msgstr "vor %1Std"

msgctxt "time since event started, hours and minutes"
msgid "%1h %2min ago"
msgstr "vor %1Std %2min"

msgid "Now"
msgstr "Jetzt"

msgctxt "relative time in minutes"
msgid "in %1min"
msgstr "in %1min"

msgctxt "relative time in hours"
msgid "in %1h"
msgstr "in %1Std"

msgctxt "relative time hours and minutes"
msgid "in %1h %2min"
msgstr "in %1Std %2min"

msgctxt "short duration in minutes"
msgid "%1min"
msgstr "%1min"

msgctxt "short duration in hours"
msgid "%1h"
msgstr "%1Std"

msgctxt "short duration hours and minutes"
msgid "%1h%2"
msgstr "%1Std%2"

msgctxt "short duration in days"
msgid "%1d"
msgstr "%1T"

msgctxt "short duration days and hours"
msgid "%1d %2h"
msgstr "%1T %2Std"

msgid "Upcoming meetings"
msgstr "Nächste Termine"

msgid "Configure your Google account\nin the widget settings."
msgstr "Konfigurieren Sie Ihr Google-Konto\nin den Widget-Einstellungen."

msgid "No upcoming events"
msgstr "Keine bevorstehenden Termine"

msgid "(no title)"
msgstr "(ohne Titel)"

msgid "All day"
msgstr "Ganztägig"

msgid "%1 is starting"
msgstr "%1 beginnt"

msgid "Join"
msgstr "Beitreten"

msgid "Google Account"
msgstr "Google-Konto"

msgid "Options"
msgstr "Optionen"

msgid "Notifications"
msgstr "Benachrichtigungen"

msgid "Notify when an event starts"
msgstr "Benachrichtigen, wenn ein Termin beginnt"

msgid "Show a reminder notification"
msgstr "Erinnerungsbenachrichtigung anzeigen"

msgid "Minutes before"
msgstr "Minuten vorher"

msgid "Reminder: %1"
msgstr "Erinnerung: %1"

msgid "In %1 minutes"
msgstr "In %1 Minuten"

msgid "Client ID:"
msgstr "Client-ID:"

msgid "Client Secret:"
msgstr "Client-Geheimnis:"

msgid "Connecting..."
msgstr "Verbindung wird hergestellt..."

msgid "Sign in with Google"
msgstr "Mit Google anmelden"

msgid "Error: could not retrieve authorization code"
msgstr "Fehler: Autorisierungscode konnte nicht abgerufen werden"

msgid "Error: token exchange failed"
msgstr "Fehler: Token-Austausch fehlgeschlagen"

msgid "Connected to Google Calendar"
msgstr "Mit Google Kalender verbunden"

msgid "Sign out"
msgstr "Abmelden"

msgid "Authentication failed. Try signing in again."
msgstr "Authentifizierung fehlgeschlagen. Bitte erneut anmelden."

msgid "Could not load events. Check your connection."
msgstr "Termine konnten nicht geladen werden. Prüfen Sie Ihre Verbindung."

msgid "Could not load events (timeout)"
msgstr "Termine konnten nicht geladen werden (Zeitüberschreitung)"

msgid "Retry"
msgstr "Erneut versuchen"

msgid "Show if nothing within (hours)"
msgstr "Anzeigen, wenn nichts innerhalb (Stunden)"

msgid "All-day event"
msgstr "Ganztägiges Ereignis"

msgid "Personalisation"
msgstr "Personalisierung"

msgid "If a timed event starts within %1h, it will be shown instead."
msgstr "Wenn ein Termin innerhalb von %1Std beginnt, wird dieser stattdessen angezeigt."

msgid "The all-day event is always shown first."
msgstr "Das ganztägige Ereignis wird immer zuerst angezeigt."

msgid "Align panel text to the left"
msgstr "Paneltext linksbündig ausrichten"

msgid "Show calendar icon"
msgstr "Kalendersymbol anzeigen"

msgid "Show generic title instead of event name"
msgstr "Allgemeinen Titel statt Terminname anzeigen"

msgid "Maximum title width (characters)"
msgstr "Maximale Titelbreite (Zeichen)"

msgid "Next event"
msgstr "Nächster Termin"

msgid "No events today"
msgstr "Keine Termine heute"

msgid "Debug"
msgstr "Debug"

msgid "Enable debug logs"
msgstr "Debug-Protokollierung aktivieren"
