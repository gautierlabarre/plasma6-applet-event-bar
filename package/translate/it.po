msgid "Events"
msgstr "Eventi"

msgid "upcoming"
msgstr "in arrivo"

msgid "Today"
msgstr "Oggi"

msgid "Tomorrow"
msgstr "Domani"

msgid "In progress"
msgstr "In corso"

msgctxt "time since event started, in minutes"
msgid "%1min ago"
msgstr "%1min fa"

msgctxt "time since event started, in hours"
msgid "%1h ago"
msgstr "%1h fa"

msgctxt "time since event started, hours and minutes"
msgid "%1h %2min ago"
msgstr "%1h %2min fa"

msgid "Now"
msgstr "Ora"

msgctxt "relative time in minutes"
msgid "in %1min"
msgstr "tra %1min"

msgctxt "relative time in hours"
msgid "in %1h"
msgstr "tra %1h"

msgctxt "relative time hours and minutes"
msgid "in %1h %2min"
msgstr "tra %1h %2min"

msgctxt "short duration in minutes"
msgid "%1min"
msgstr "%1min"

msgctxt "short duration in hours"
msgid "%1h"
msgstr "%1h"

msgctxt "short duration hours and minutes"
msgid "%1h%2"
msgstr "%1h%2"

msgctxt "short duration in days"
msgid "%1d"
msgstr "%1g"

msgctxt "short duration days and hours"
msgid "%1d %2h"
msgstr "%1g %2h"

msgid "Upcoming meetings"
msgstr "Prossimi appuntamenti"

msgid "Configure your Google account\nin the widget settings."
msgstr "Configura il tuo account Google\nnelle impostazioni del widget."

msgid "No upcoming events"
msgstr "Nessun evento in programma"

msgid "(no title)"
msgstr "(senza titolo)"

msgid "All day"
msgstr "Tutto il giorno"

msgid "%1 is starting"
msgstr "%1 sta iniziando"

msgid "Join"
msgstr "Partecipa"

msgid "Google Account"
msgstr "Account Google"

msgid "Options"
msgstr "Opzioni"

msgid "Notify when an event starts"
msgstr "Notifica all'inizio di un evento"

msgid "Show a reminder notification"
msgstr "Mostra una notifica di promemoria"

msgid "Minutes before"
msgstr "Minuti prima"

msgid "Reminder: %1"
msgstr "Promemoria: %1"

msgid "In %1 minutes"
msgstr "Tra %1 minuti"

msgid "Client ID:"
msgstr "ID client:"

msgid "Client Secret:"
msgstr "Segreto client:"

msgid "Connecting..."
msgstr "Connessione in corso..."

msgid "Sign in with Google"
msgstr "Accedi con Google"

msgid "Error: could not retrieve authorization code"
msgstr "Errore: impossibile recuperare il codice di autorizzazione"

msgid "Error: token exchange failed"
msgstr "Errore: scambio token fallito"

msgid "Connected to Google Calendar"
msgstr "Connesso a Google Calendar"

msgid "Sign out"
msgstr "Disconnetti"

msgid "Authentication failed. Try signing in again."
msgstr "Autenticazione fallita. Prova ad accedere di nuovo."

msgid "Could not load events. Check your connection."
msgstr "Impossibile caricare gli eventi. Controlla la tua connessione."

msgid "Retry"
msgstr "Riprova"

msgid "Show all-day event if nothing within (hours)"
msgstr "Mostrare evento della giornata se nessun evento entro (ore)"

msgid "If a timed event starts within %1h, it will be shown instead."
msgstr "Se un evento puntuale inizia entro %1h, verrà mostrato al suo posto."

msgid "The all-day event is always shown first."
msgstr "L'evento della giornata viene sempre mostrato per primo."

msgid "Align panel text to the left"
msgstr "Allineare il testo del pannello a sinistra"

msgid "Show calendar icon"
msgstr "Mostra icona calendario"

msgid "Show generic title instead of event name"
msgstr "Mostra titolo generico al posto del nome dell'evento"

msgid "Maximum title width (characters)"
msgstr "Larghezza massima del titolo (caratteri)"

msgid "Next event"
msgstr "Prossimo evento"

msgid "No events today"
msgstr "Nessun evento oggi"
