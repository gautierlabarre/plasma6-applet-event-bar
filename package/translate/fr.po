msgid "Events"
msgstr "Événements"

msgid "upcoming"
msgstr "à venir"

msgid "Today"
msgstr "Aujourd'hui"

msgid "Tomorrow"
msgstr "Demain"

msgctxt "time since event started, in minutes"
msgid "%1min ago"
msgstr "il y a %1min"

msgctxt "time since event started, in hours"
msgid "%1h ago"
msgstr "il y a %1h"

msgctxt "time since event started, hours and minutes"
msgid "%1h %2min ago"
msgstr "il y a %1h %2min"

msgid "Now"
msgstr "Maintenant"

msgctxt "relative time in minutes"
msgid "in %1min"
msgstr "dans %1min"

msgctxt "relative time in hours"
msgid "in %1h"
msgstr "dans %1h"

msgctxt "relative time hours and minutes"
msgid "in %1h %2min"
msgstr "dans %1h %2min"

msgctxt "short duration in minutes"
msgid "%1min"
msgstr "%1min"

msgctxt "short duration in hours"
msgid "%1h"
msgstr "%1h"

msgctxt "short duration hours and minutes"
msgid "%1h%2"
msgstr "%1h%2"

msgctxt "short duration in days"
msgid "%1d"
msgstr "%1j"

msgctxt "short duration days and hours"
msgid "%1d %2h"
msgstr "%1j %2h"

msgid "Upcoming meetings"
msgstr "Prochaines réunions"

msgid "Configure your Google account\nin the widget settings."
msgstr "Configurez votre compte Google\ndans les paramètres du widget."

msgid "No upcoming events"
msgstr "Aucun événement à venir"

msgid "(no title)"
msgstr "(sans titre)"

msgid "All day"
msgstr "Journée"

msgid "%1 is starting"
msgstr "%1 commence"

msgid "Join"
msgstr "Rejoindre"

msgid "Google Account"
msgstr "Compte Google"

msgid "Options"
msgstr "Options"

msgid "Notifications"
msgstr "Notifications"

msgid "Notify when an event starts"
msgstr "Notifier au début d'un événement"

msgid "Show a reminder notification"
msgstr "Afficher une notification de rappel"

msgid "Minutes before"
msgstr "Minutes avant"

msgid "Reminder: %1"
msgstr "Rappel : %1"

msgid "In %1 minutes"
msgstr "Dans %1 minutes"

msgid "Client ID:"
msgstr "Client ID :"

msgid "Client Secret:"
msgstr "Client Secret :"

msgid "Connecting..."
msgstr "Connexion en cours..."

msgid "Sign in with Google"
msgstr "Se connecter à Google"

msgid "Error: could not retrieve authorization code"
msgstr "Erreur : impossible de récupérer le code d'autorisation"

msgid "Error: token exchange failed"
msgstr "Erreur : échec de l'échange de tokens"

msgid "Connected to Google Calendar"
msgstr "Connecté à Google Calendar"

msgid "Sign out"
msgstr "Se déconnecter"

msgid "Authentication failed. Try signing in again."
msgstr "Échec de l'authentification. Essayez de vous reconnecter."

msgid "Could not load events. Check your connection."
msgstr "Impossible de charger les événements. Vérifiez votre connexion."

msgid "Could not load events (timeout)"
msgstr "Impossible de charger les événements (délai dépassé)"

msgid "Retry"
msgstr "Réessayer"

msgid "Show if nothing within (hours)"
msgstr "Afficher si aucun événement dans (heures)"

msgid "All-day event"
msgstr "Événement de la journée"

msgid "Personalisation"
msgstr "Personnalisation"

msgid "If a timed event starts within %1h, it will be shown instead."
msgstr "Si un événement ponctuel commence dans les %1h, il sera affiché à la place."

msgid "The all-day event is always shown first."
msgstr "L'événement de la journée est toujours affiché en priorité."

msgid "Align panel text to the left"
msgstr "Aligner le texte du panneau à gauche"

msgid "Show calendar icon"
msgstr "Afficher l'icône de calendrier"

msgid "Show generic title instead of event name"
msgstr "Afficher un titre générique au lieu du nom de l'événement"

msgid "Maximum title width (characters)"
msgstr "Largeur maximale du titre (caractères)"

msgid "Next event"
msgstr "Prochain événement"

msgid "No events today"
msgstr "Aucun événement aujourd'hui"

msgid "Debug"
msgstr "Débogage"

msgid "Enable debug logs"
msgstr "Activer les logs de débogage"
