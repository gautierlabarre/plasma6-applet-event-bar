msgstr "Próximas reuniones"

msgid "Configure your Google account\nin the widget settings."
msgstr "Configura tu cuenta de Google\nen los ajustes del widget."

msgid "No upcoming events"
msgstr "No hay eventos próximos"

msgid "(no title)"
msgstr "(sin título)"

msgid "All day"
msgstr "Todo el día"

