msgstr "Evento del día"

msgid "Personalisation"
msgstr "Personalización"

msgid "If a timed event starts within %1h, it will be shown instead."
msgstr "Si un evento puntual comienza en las próximas %1h, se mostrará en su lugar."

msgid "The all-day event is always shown first."
msgstr "El evento del día siempre se muestra primero."

msgid "Align panel text to the left"
msgstr "Alinear el texto del panel a la izquierda"

