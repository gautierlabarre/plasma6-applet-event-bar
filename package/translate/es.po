msgstr "%1 está comenzando"

msgid "Join"
msgstr "Unirse"

msgid "Google Account"
msgstr "Cuenta de Google"

msgid "Options"
msgstr "Opciones"

msgid "Notifications"
msgstr "Notificaciones"

msgid "Notify when an event starts"
msgstr "Notificar cuando comience un evento"

msgid "Show a reminder notification"
msgstr "Mostrar una notificación de recordatorio"

msgid "Minutes before"
msgstr "Minutos antes"

msgid "Reminder: %1"
msgstr "Recordatorio: %1"

msgid "In %1 minutes"
msgstr "En %1 minutos"

msgid "Client ID:"
msgstr "ID de cliente:"

msgid "Client Secret:"
msgstr "Secreto de cliente:"

msgid "Connecting..."
msgstr "Conectando..."

msgid "Sign in with Google"
msgstr "Iniciar sesión con Google"

msgid "Error: could not retrieve authorization code"
msgstr "Error: no se pudo obtener el código de autorización"

msgid "Error: token exchange failed"
msgstr "Error: falló el intercambio de tokens"

